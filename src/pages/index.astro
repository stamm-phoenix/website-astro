---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import QuickInfoCard from '../components/QuickInfoCard.astro';
import CTASection from '../components/CTASection.astro';
import Heading from '../components/Heading.astro';
import CardGrid from '../components/CardGrid.astro';
import BlogCarousel from '../components/BlogCarousel.astro';

const hero = {
  title: 'Gemeinschaft. Abenteuer. Verantwortung.',
  subtitle: 'Willkommen beim DPSG Stamm Phoenix Feldkirchen-Westerham',
  description:
    'Pfadfinden bedeutet bei uns mehr als nur draußen sein – wir entdecken gemeinsam die Natur, stellen uns spannenden Herausforderungen und übernehmen Verantwortung füreinander. Kinder und Jugendliche lernen im Team ihre eigenen Stärken kennen und wachsen dabei über sich hinaus.',
  primaryButtonText: 'Jetzt mitmachen',
  primaryButtonLink: '/mitmachen',
  secondaryButtonText: 'Gruppenstunden',
  secondaryButtonLink: '/gruppenstunden',
};

const quickInfo = [
  {
    icon: '🌱',
    title: 'Für alle Altersstufen',
    description:
      'Ob Wölfling, Jungpfadfinder, Pfadfinder oder Rover – wir bieten altersgerechte Gruppenstunden und Programme, die Spaß machen und gleichzeitig wichtige Fähigkeiten fördern.',
  },
  {
    icon: '⛺',
    title: 'Draußen erleben',
    description:
      'Zeltlager, Hikes und spannende Projekte stärken Selbstständigkeit, Teamgeist und den Mut, Neues auszuprobieren.',
  },
  {
    icon: '🤝',
    title: 'Werte leben',
    description:
      'Respekt, Verantwortung und Mitbestimmung sind die Grundlagen unseres Handelns. Gemeinsam gestalten wir unser Pfadfinderleben und tragen diese Werte auch nach außen.',
  },
];

const callToAction = {
  title: 'Mach mit!',
  description:
    'Du möchtest Teil der Pfadfinder werden? Dann komm vorbei und erlebe Abenteuer, Gemeinschaft und jede Menge Spaß.',
  buttonText: 'Jetzt mitmachen',
  buttonLink: '/mitmachen',
};
---

<BaseLayout
  title="Willkommen | Stamm Phoenix"
  description="DPSG Stamm Phoenix Feldkirchen-Westerham – Pfadfinden vor Ort."
>
  <Header slot="header" />

  <HeroSection
    badge="DPSG Feldkirchen-Westerham"
    title={hero.title}
    subtitle={hero.subtitle}
    description={hero.description}
    primaryButtonText={hero.primaryButtonText}
    primaryButtonLink={hero.primaryButtonLink}
    secondaryButtonText={hero.secondaryButtonText}
    secondaryButtonLink={hero.secondaryButtonLink}
  />

  <section class="mt-12 space-y-4" aria-labelledby="quick-info-heading">
    <div class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
      <Heading level={2} id="quick-info-heading" variant="section">Was uns ausmacht</Heading>
    </div>
    <CardGrid cols={3}>
      {
        quickInfo.map((info) => (
          <QuickInfoCard icon={info.icon} title={info.title} description={info.description} />
        ))
      }
    </CardGrid>
  </section>

  <BlogCarousel />

  <CTASection
    label="Jetzt entdecken"
    title={callToAction.title}
    description={callToAction.description}
    buttonText={callToAction.buttonText}
    buttonLink={callToAction.buttonLink}
  />

  <Footer slot="footer" />
</BaseLayout>
